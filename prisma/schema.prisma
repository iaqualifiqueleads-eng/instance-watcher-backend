generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model LastStatusInstance {
  id Int @id

  name         String
  phone_number String
  work_space   String
  status       String
  system       String  @default("SYSTEM")
  color        String  @default("#D705F7")
  celular      String  @default("---")
}
